{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "serve": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node24 --outfile=dist/index.js",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:push": "prisma db push --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^7.5.0",
    "fastify": "^5.8.2"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "esbuild": "^0.27.4",
    "prisma": "^7.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
